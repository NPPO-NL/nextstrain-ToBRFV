{
  "title": "Real-time tracking of Tomato brown rugose fruit virus (ToBRFV) outbreaks using Nextstrain (v5)",
  "maintainers": [
    {
      "name": "Pier P.M. de Koning, Bart T.L.H. van de Vossenberg en Michael Visser",
      "url": "https://english.nvwa.nl/topics/national-plant-protection-organization-nppo"
    }
  ],
  "display_defaults": {
    "map_triplicate": true,
    "color_by": "country",
    "transmission_lines": true,
    "geo_resolution": "country"
  },
  "colorings": [
    {
      "key": "confidence",
      "title": "Confidence",
      "type": "continuous"
    },
    {
      "key": "country",
      "title": "Country",
      "type": "categorical"
    },
    {
      "key": "genotype",
      "title": "Genotype",
      "type": "categorical"
    },
    {
      "key": "num_date",
      "title": "Sampling date",
      "type": "continuous"
    },
    {
      "key": "host",
      "title": "Host",
      "type": "categorical"
    },
    {
      "key": "sampled",
      "title": "Plant tissue sampled",
      "type": "categorical"
    },
    {
      "key": "isolate",
      "title": "Isolate",
      "type": "categorical"
    },
    {
      "key": "continent",
      "title": "Continent",
      "type": "categorical"
    },
    {
      "key": "state",
      "title": "State",
      "type": "categorical"
    },
    {
      "key": "municipality",
      "title": "Municipality",
      "type": "categorical"
    }
  ],
  "geo_resolutions": [
    "continent",
    "country",
    "state",
    "municipality"
  ],
  "panels": [
    "tree",
    "map",
    "entropy"
  ],
  "filters": [
    "continent",
    "country",
    "municipality",
    "host",
    "sampled",
    "isolate",
    "subsample"
  ]
}

